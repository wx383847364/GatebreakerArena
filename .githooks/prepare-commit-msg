#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
source "${REPO_ROOT}/.githooks/_common"
MESSAGE_FILE="$1"
SOURCE="${2:-}"

if [[ "${SOURCE}" != "merge" ]] && ! git -C "${REPO_ROOT}" rev-parse -q --verify MERGE_HEAD >/dev/null; then
  exit 0
fi

run_python_script "${REPO_ROOT}" "${REPO_ROOT}/tools/doc_maintenance/update_project_docs.py" \
  --doc-root "${REPO_ROOT}/doc" \
  prepare-commit-message \
  --message-file "${MESSAGE_FILE}" \
  --source "${SOURCE}"
